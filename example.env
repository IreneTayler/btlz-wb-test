# PostgreSQL (defaults used by docker-compose; localhost for local dev)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tariffs_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345678

# WB API (required for box tariffs fetch)
# Get token from https://seller.wildberries.ru/
WB_API_TOKEN=

# Google Sheets (optional). Path to service account JSON inside container.
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account.json
# One or more spreadsheet IDs (comma-separated). Overrides DB spreadsheets table when set.
SPREADSHEET_IDS=
# Or single spreadsheet ID
SPREADSHEET_ID=